# Vite reads VITE_* at build time. Set in Vercel → Project → Settings → Environment Variables
# for Production and Preview (Preview should point at the same API or a staging API).

# Public API base URL — no trailing slash. Example: https://portfolio-maker-api.onrender.com
# Leave empty for local dev (Vite proxies /api → http://localhost:5000).
VITE_API_URL=
