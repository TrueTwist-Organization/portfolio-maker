# Copy to backend/.env for local development, or set in your host (Render, Railway, Fly, etc.)

PORT=5000
NODE_ENV=development

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Must be the project root only — do NOT append /rest/v1/ (the SDK adds that).
# Prefer the legacy service_role JWT (starts with eyJ...) for Node + @supabase/supabase-js.
# If you only see sb_secret_ keys and health check fails, scroll the same page to "Legacy API keys" and use service_role here.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional alias for the same value:
# SUPABASE_SECRET_KEY=

# Run supabase/migrations/20250514120000_portfolio_maker.sql in the Supabase SQL editor (or supabase db push) once.

# Strong random string — required when NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-string

# CORS: browser Origin must match exactly (no trailing slash)
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=https://preview-abc.vercel.app,https://www.yourdomain.com
# ALLOWED_ORIGINS=

# AI features
OPENAI_API_KEY=sk-...
REPLICATE_API_TOKEN=r8_...
ELEVENLABS_API_KEY=...
